<?xml version="1.0"?>
<!--
/**
 * kwtSMS Integration for Magento 2
 * Default configuration values
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <kwtsms>
            <general>
                <enabled>0</enabled>
                <test_mode>0</test_mode>
                <debug>0</debug>
                <default_country_code>965</default_country_code>
                <sender_id>KWT-SMS</sender_id>
            </general>
            <integrations>
                <order_new>1</order_new>
                <order_status_change>1</order_status_change>
                <order_shipped>1</order_shipped>
                <order_invoiced>0</order_invoiced>
                <order_refunded>0</order_refunded>
                <order_cancelled>1</order_cancelled>
                <customer_welcome>0</customer_welcome>
                <admin_new_order>1</admin_new_order>
                <admin_new_customer>0</admin_new_customer>
                <admin_low_stock>0</admin_low_stock>
            </integrations>
            <admin_alerts>
                <low_stock_threshold>5</low_stock_threshold>
            </admin_alerts>
        </kwtsms>
    </default>
</config>
