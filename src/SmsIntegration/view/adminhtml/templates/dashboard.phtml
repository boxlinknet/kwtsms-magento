<script>
require(['jquery'], function($) {
    function doAjax(url, btnId) {
        var btn = $(btnId);
        var result = $('#kwtsms-action-result');

        btn.prop('disabled', true);
        result.text('Processing...').css('color', '#333');

        $.ajax({
            url: url,
            type: 'POST',
            dataType: 'json',
            data: { form_key: window.FORM_KEY },
            success: function(response) {
                if (response.success) {
                    result.text(response.message || 'Success!').css('color', 'green');
                    if (response.balance) {
                        result.text(result.text() + ' Balance: ' + response.balance);
                    }
                } else {
                    result.text(response.message || 'Failed.').css('color', 'red');
                }
            },
            error: function() {
                result.text('Request failed. Check your network and try again.').css('color', 'red');
            },
            complete: function() {
                btn.prop('disabled', false);
            }
        });
    }

    $('#kwtsms-sync-btn').on('click', function() {
        doAjax('<?= $block->escapeJs($syncUrl) ?>', '#kwtsms-sync-btn');
    });
});
</script>
