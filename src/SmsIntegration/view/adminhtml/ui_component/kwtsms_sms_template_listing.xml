<?xml version="1.0" encoding="UTF-8"?>
<!--
/**
 * kwtSMS SMS Template listing UI component.
 * Displays the kwtsms_sms_template table records in an admin grid.
 */
-->
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">kwtsms_sms_template_listing.kwtsms_sms_template_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <spinner>kwtsms_sms_template_columns</spinner>
        <deps>
            <dep>kwtsms_sms_template_listing.kwtsms_sms_template_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="kwtsms_sms_template_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>KwtSms_SmsIntegration::templates</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="kwtsms_sms_template_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="kwtsms_sms_template_columns">
        <column name="entity_id" sortOrder="10">
            <settings>
                <filter>text</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>

        <column name="name" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Name</label>
            </settings>
        </column>

        <column name="event_type" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Event Type</label>
            </settings>
        </column>

        <column name="recipient_type" component="Magento_Ui/js/grid/columns/select" sortOrder="40">
            <settings>
                <filter>select</filter>
                <label translate="true">Recipient</label>
                <dataType>select</dataType>
                <options>
                    <option name="customer" xsi:type="array">
                        <item name="value" xsi:type="string">customer</item>
                        <item name="label" xsi:type="string" translate="true">Customer</item>
                    </option>
                    <option name="admin" xsi:type="array">
                        <item name="value" xsi:type="string">admin</item>
                        <item name="label" xsi:type="string" translate="true">Admin</item>
                    </option>
                    <option name="both" xsi:type="array">
                        <item name="value" xsi:type="string">both</item>
                        <item name="label" xsi:type="string" translate="true">Both</item>
                    </option>
                </options>
            </settings>
        </column>

        <column name="updated_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date" sortOrder="60">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Last Updated</label>
                <dataType>date</dataType>
            </settings>
        </column>

        <actionsColumn name="actions" class="KwtSms\SmsIntegration\Ui\Component\Listing\Columns\TemplateActions" sortOrder="70">
            <settings>
                <label translate="true">Action</label>
                <indexField>entity_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
